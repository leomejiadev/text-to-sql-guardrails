# Copiar a `.env` y completar valores. `.env` está ignorado por git.

# postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/text_to_sql

# redis://<host>:<port>/<db>
REDIS_URL=redis://localhost:6379/0

# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

EMBEDDING_MODEL=models/gemini-embedding-001

# postgresql+psycopg2://<user>:<password>@<host>:<port>/<db>
CLIENT_DATABASE_URL=

# Para tests de integración
TEST_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5434/test_text_to_sql

# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Opcional: habilita fallback a Claude Haiku cuando el LLM primario falla
ANTHROPIC_API_KEY=

# Segundos entre re-indexados periódicos del schema (86400 = 24h)
REINDEX_INTERVAL_SECONDS=86400
